{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug SMC Hoarding App",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "server.ts"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "PORT": "3000"
      }
    }
  ]
}